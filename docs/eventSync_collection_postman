{
  "info": {
    "name": "EventSync-2026 API",
    "description": "Collection complète pour tester EventSync Backend",
    "_postman_id": "eventsync-2026-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "eventId",
      "value": "",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "speakerId",
      "value": "",
      "type": "string"
    },
    {
      "key": "questionId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Admin Authentication",
      "item": [
        {
          "name": "Login Admin",
          "method": "POST",
          "header": [],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"email\": \"admin@eventsync.com\",\n  \"password\": \"adminpassword123\"\n}",
            "options": { "raw": { "language": "json" } }
          },
          "url": "{{base_url}}/api/admin/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set(\"accessToken\", json.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", json.refreshToken);",
                  "    console.log(\"Access Token saved\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Me (Profile)",
          "method": "GET",
          "header": [
            { "key": "Authorization", "value": "Bearer {{accessToken}}" }
          ],
          "url": "{{base_url}}/api/admin/me"
        },
        {
          "name": "Refresh Token",
          "method": "POST",
          "header": [],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
            "options": { "raw": { "language": "json" } }
          },
          "url": "{{base_url}}/api/admin/refresh"
        },
        {
          "name": "Logout",
          "method": "POST",
          "header": [
            { "key": "Authorization", "value": "Bearer {{accessToken}}" }
          ],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
          },
          "url": "{{base_url}}/api/admin/logout"
        }
      ]
    },
    {
      "name": "🌐 Public Endpoints",
      "item": [
        {
          "name": "Get All Events",
          "method": "GET",
          "url": "{{base_url}}/api/events"
        },
        {
          "name": "Get Event By ID",
          "method": "GET",
          "url": "{{base_url}}/api/events/{{eventId}}"
        },
        {
          "name": "Get All Speakers",
          "method": "GET",
          "url": "{{base_url}}/api/speakers"
        },
        {
          "name": "Get Speaker By ID",
          "method": "GET",
          "url": "{{base_url}}/api/speakers/{{speakerId}}"
        },
        {
          "name": "Get Session By ID (Detail)",
          "method": "GET",
          "url": "{{base_url}}/api/sessions/{{sessionId}}"
        },
        {
          "name": "Get Questions by Session",
          "method": "GET",
          "url": "{{base_url}}/api/questions/sessions/{{sessionId}}/questions"
        }
      ]
    },
    {
      "name": "🔧 Admin - Protected",
      "item": [
        {
          "name": "Create Event",
          "method": "POST",
          "header": [
            { "key": "Authorization", "value": "Bearer {{accessToken}}" }
          ],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"title\": \"Conférence Tech 2026\",\n  \"description\": \"Événement majeur sur l'IA et le Web\",\n  \"startDate\": \"2026-06-15T09:00:00.000Z\",\n  \"endDate\": \"2026-06-15T18:00:00.000Z\",\n  \"location\": \"Paris La Défense\"\n}"
          },
          "url": "{{base_url}}/api/admin/event"
        },
        {
          "name": "Create Session",
          "method": "POST",
          "header": [
            { "key": "Authorization", "value": "Bearer {{accessToken}}" }
          ],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"roomId\": \"room-id-ici\",\n  \"title\": \"Keynote Intelligence Artificielle\",\n  \"description\": \"Présentation des tendances IA 2026\",\n  \"startTime\": \"2026-06-15T10:00:00.000Z\",\n  \"endTime\": \"2026-06-15T11:30:00.000Z\",\n  \"capacity\": 250,\n  \"speakerIds\": [\"speaker-id-1\", \"speaker-id-2\"]\n}"
          },
          "url": "{{base_url}}/api/sessions"
        },
        {
          "name": "Update Session",
          "method": "PUT",
          "header": [
            { "key": "Authorization", "value": "Bearer {{accessToken}}" }
          ],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"roomId\": \"room-id-ici\",\n  \"title\": \"Keynote IA - Mise à jour\",\n  \"description\": \"Description mise à jour\",\n  \"startTime\": \"2026-06-15T10:00:00.000Z\",\n  \"endTime\": \"2026-06-15T11:30:00.000Z\",\n  \"capacity\": 300,\n  \"speakerIds\": [\"speaker-id-1\"]\n}"
          },
          "url": "{{base_url}}/api/sessions/{{sessionId}}"
        },
        {
          "name": "Create Speaker",
          "method": "POST",
          "header": [
            { "key": "Authorization", "value": "Bearer {{accessToken}}" }
          ],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"fullName\": \"Alice Johnson\",\n  \"photoUrl\": \"https://i.pravatar.cc/150?img=1\",\n  \"bio\": \"Expert en Intelligence Artificielle\",\n  \"speakerLinks\": [\n    {\"platform\": \"linkedin\", \"url\": \"https://linkedin.com/in/alice\"},\n    {\"platform\": \"twitter\", \"url\": \"https://twitter.com/alice\"}\n  ]\n}"
          },
          "url": "{{base_url}}/api/speakers"
        }
      ]
    },
    {
      "name": "💬 Questions (Participants)",
      "item": [
        {
          "name": "Create Question",
          "method": "POST",
          "header": [],
          "body": {
            "mode": "raw",
            "raw": "{\n  \"content\": \"Quelle est la version de React utilisée dans ce projet ?\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"authorName\": \"Jean Dupont\"\n}"
          },
          "url": "{{base_url}}/api/questions"
        },
        {
          "name": "Upvote Question",
          "method": "POST",
          "header": [],
          "url": "{{base_url}}/api/questions/{{questionId}}/upvote"
        }
      ]
    }
  ]
}