    {
      "name": "🔐 Auth — Admin",
      "item": [
        {
          "name": "Login ✅",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@eventsync.com\",\n  \"password\": \"adminpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/login", "host": ["{{base_url}}"], "path": ["admin","login"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test(\"accessToken présent\", () => pm.expect(json.accessToken).to.be.a('string'));",
              "pm.collectionVariables.set('accessToken', json.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.refreshToken);",
              "console.log('✅ Tokens sauvegardés');"
            ]}
          }]
        },
        {
          "name": "Login — mauvais mot de passe ❌",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@eventsync.com\",\n  \"password\": \"mauvaismdp\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/login", "host": ["{{base_url}}"], "path": ["admin","login"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test(\"Status 401\", () => pm.response.to.have.status(401));"
            ]}
          }]
        },
        {
          "name": "Me (profil connecté) ✅",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{base_url}}/admin/me", "host": ["{{base_url}}"], "path": ["admin","me"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"email présent\", () => pm.expect(pm.response.json().email).to.be.a('string'));"
            ]}
          }]
        },
        {
          "name": "Me — sans token ❌",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/admin/me", "host": ["{{base_url}}"], "path": ["admin","me"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test(\"Status 401\", () => pm.response.to.have.status(401));"
            ]}
          }]
        },
        {
          "name": "Refresh Token ✅",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/refresh", "host": ["{{base_url}}"], "path": ["admin","refresh"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);"
            ]}
          }]
        },
        {
          "name": "Logout ✅",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/logout", "host": ["{{base_url}}"], "path": ["admin","logout"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test(\"Status 200 ou 204\", () => pm.expect(pm.response.code).to.be.oneOf([200,204]));"
            ]}
          }]
